{
  "name": "whattoeat",
  "private": true,
  "engines": { "node": ">=22.5.0" },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "check": "pnpm -r --if-present run check && prettier --check \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "format": "prettier --write \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "test": "pnpm -r --if-present run test",
    "dev": "pnpm --filter @whattoeat/server run dev"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "typescript": "^5.9.0"
  }
}
