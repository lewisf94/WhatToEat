{
  "name": "eatme",
  "private": true,
  "engines": { "node": ">=22.5.0" },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "check": "pnpm -r --if-present run check && prettier --check \"{apps,packages}/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{apps,packages}/**/*.{ts,tsx}\"",
    "test": "pnpm -r --if-present run test",
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @eatme/server dev\" \"pnpm --filter @eatme/web dev\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.9.0"
  }
}
